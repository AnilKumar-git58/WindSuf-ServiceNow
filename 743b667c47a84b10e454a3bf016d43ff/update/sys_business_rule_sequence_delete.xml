<?xml version="1.0" encoding="UTF-8"?><record_update>
    <sys_business_rule action="INSERT_OR_UPDATE">
        <active>true</active>
        <abort_action>false</abort_action>
        <access>package_private</access>
        <action_delete>true</action_delete>
        <action_insert>false</action_insert>
        <action_query>false</action_query>
        <action_update>false</action_update>
        <add_message>false</add_message>
        <advanced>true</advanced>
        <change_fields>false</change_fields>
        <client_callable>false</client_callable>
        <collection>x_2025153_windsu_0_git_windsurf</collection>
        <condition/>
        <description>Adjust sequence numbers when a record is deleted to fill gaps</description>
        <execute_function>false</execute_function>
        <filter_condition/>
        <is_rest>false</is_rest>
        <message/>
        <name>Sequence Adjustment on Delete</name>
        <order>300</order>
        <priority>100</priority>
        <query_condition/>
        <run_when>before</run_when>
        <script><![CDATA[// Reorder sequence numbers on delete
(function executeRule(current, previous /*null when async*/) {

    // Get the number of the record being deleted
    var deletedNumber = parseInt(current.number);
    
    if (!isNaN(deletedNumber)) {
        var sequenceManager = new x_2025153_windsu_0.SequenceManager();
        
        // Reorder sequence to fill the gap
        sequenceManager.reorderOnDelete(
            current.getTableName(),
            'number',
            deletedNumber
        );
    }

})(current, previous);]]></script>
